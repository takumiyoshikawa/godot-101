# Godot 4+ specific ignores
.godot/
.import/

# XDG sandboxes used by headless runs
.tmp-godot-data/
.tmp-godot-config/
.tmp-godot-cache/

# Headless run logs
logs/

# Build output
build/
exports/

# Imported translations (these are automatically generated)
*.translation

# System
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.code-workspace

.playwright/
.playwright-cli/

# Generated 3D assets (rebuild via .agents/skills/blender-asset/build.sh)
assets/models/*.glb
assets/models/*.glb.import

# Python bytecode
__pycache__/
*.pyc


