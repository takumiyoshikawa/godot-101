; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="godot-101"
run/main_scene="res://shotgun_view.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Don": "res://features/characters/don.dch",
"Luca": "res://features/characters/luca.dch",
"Tomaso": "res://features/characters/tomaso.dch"
}
directories/dtl_directory={
"intro": "res://features/dialogue/intro.dtl"
}
layout/style_directory={}

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[gui]

theme/custom_font="res://assets/fonts/NotoSansJP-Regular.otf"

[input]

dialogic_default_action={
"deadzone": 0.5,
